HTTP_PORT=8080
DATABASE_URL=postgres://hidro:hidro@localhost:5432/hidro?sslmode=disable
JWT_SECRET=dev-secret-change-me
JWT_TTL=24h

# MQTT (backend kullanıcısı; mosquitto passwd ile eşleşmeli — bkz. deploy/mosquitto/setup-auth.sh)
MQTT_BROKER=tcp://localhost:1883
MQTT_CLIENT_ID=hidro-backend
MQTT_USERNAME=backend
MQTT_PASSWORD=backendpass

# Telemetri saklama (gün). 0 = sınırsız (retention kapalı).
READING_RETENTION_DAYS=30

# WebSocket izin verilen origin'ler (virgülle ayrılmış). Boş/"*" = hepsi (yalnız geliştirme).
ALLOWED_ORIGINS=

# Migration SQL dosyalarının bulunduğu dizin
MIGRATIONS_DIR=migrations

# Web UI statik dosyaların bulunduğu dizin
WEB_DIR=web

LOG_LEVEL=info
